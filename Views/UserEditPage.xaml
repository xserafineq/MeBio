<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MeBio.ViewModels"
             x:Class="MeBio.Views.UserEditPage"
             x:DataType="vm:UserEditViewModel"
             Title="Edycja użytkownika"
             BackgroundColor="{StaticResource AppBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="14">
            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Padding="20" Spacing="12">
                    <Label Text="Imię" Style="{StaticResource FieldLabel}" />
                    <Entry Text="{Binding FirstName}" Style="{StaticResource DarkEntry}" />

                    <Label Text="Nazwisko" Style="{StaticResource FieldLabel}" />
                    <Entry Text="{Binding LastName}" Style="{StaticResource DarkEntry}" />

                    <Label Text="Email" Style="{StaticResource FieldLabel}" />
                    <Entry Text="{Binding Email}" Keyboard="Email" Style="{StaticResource DarkEntry}" />

                    <Label Text="Hasło" Style="{StaticResource FieldLabel}" IsVisible="{Binding IsNew}" />
                    <Label Text="Nowe hasło" Style="{StaticResource FieldLabel}"
                           IsVisible="{Binding IsNew, Converter={StaticResource InvertedBoolConverter}}" />
                    <Entry Text="{Binding Password}" IsPassword="True" Style="{StaticResource DarkEntry}" />

                    <Label Text="Powtórz hasło" Style="{StaticResource FieldLabel}" />
                    <Entry Text="{Binding ConfirmPassword}" IsPassword="True" Style="{StaticResource DarkEntry}" />

                    <Label Text="Wiek" Style="{StaticResource FieldLabel}" />
                    <Entry Text="{Binding AgeText}" Keyboard="Numeric" Style="{StaticResource DarkEntry}" />

                    <Label Text="Płeć" Style="{StaticResource FieldLabel}" />
                    <Picker x:Name="GenderPicker" ItemsSource="{Binding Genders}" SelectedItem="{Binding Gender}">
                        <Picker.ItemDisplayBinding>
                            <Binding Converter="{StaticResource GenderConverter}" />
                        </Picker.ItemDisplayBinding>
                    </Picker>

                    <Label Text="Rola" Style="{StaticResource FieldLabel}" />
                    <Picker x:Name="RolePicker" SelectedItem="{Binding Role}" />

                    <HorizontalStackLayout Spacing="10">
                        <CheckBox IsChecked="{Binding IsVerified}" Color="{StaticResource AccentGreen}" />
                        <Label Text="Zweryfikowany" VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <Button Text="Zapisz" Command="{Binding SaveCommand}" Style="{StaticResource AccentButton}" />
                    <Button Text="Anuluj" Command="{Binding CancelCommand}" Style="{StaticResource OutlineButton}" />
                    <Label Text="{Binding StatusMessage}" Style="{StaticResource StatusLabel}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
