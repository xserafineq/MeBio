<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MeBio.ViewModels"
             x:Class="MeBio.Views.FingerprintCapturePage"
             x:DataType="vm:FingerprintCaptureViewModel"
             Title="Odcisk palca z pliku"
             BackgroundColor="{StaticResource AppBackground}">

    <Grid RowDefinitions="*,Auto,Auto" Padding="16" RowSpacing="12">
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="24">
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="14">
                <Label Text="Wybierz plik z odciskiem"
                       TextColor="{StaticResource TextPrimary}"
                       FontAttributes="Bold"
                       FontSize="18"
                       HorizontalTextAlignment="Center" />
                <Label Text="{Binding StatusMessage}"
                       TextColor="{StaticResource MutedText}"
                       FontSize="13"
                       HorizontalTextAlignment="Center" />
                <Label Text="Obsługiwane formaty: JPG, PNG, TIFF"
                       TextColor="{StaticResource MutedText}"
                       FontSize="12"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="14"
                IsVisible="{Binding ShowAuthResult}">
            <VerticalStackLayout Spacing="6">
                <Label Text="Nie udało się"
                       TextColor="{StaticResource DangerRed}"
                       FontAttributes="Bold"
                       FontSize="15"
                       HorizontalTextAlignment="Center" />
                <Label Text="{Binding AuthResultMessage}"
                       TextColor="{StaticResource DangerRed}"
                       FontSize="13"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Border>

        <VerticalStackLayout Grid.Row="2" Spacing="12">
            <Button Text="Wybierz plik" Command="{Binding PickFromFileCommand}" Style="{StaticResource AccentButton}" />
            <Button Text="Anuluj" Command="{Binding CancelCommand}" Style="{StaticResource OutlineButton}" />
        </VerticalStackLayout>

        <ActivityIndicator Grid.RowSpan="3" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                           Color="{StaticResource AccentGreen}" VerticalOptions="Center" />
    </Grid>
</ContentPage>
