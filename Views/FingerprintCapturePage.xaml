<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MeBio.ViewModels"
             x:Class="MeBio.Views.FingerprintCapturePage"
             x:DataType="vm:FingerprintCaptureViewModel"
             Title="Skan odcisku palca"
             BackgroundColor="{StaticResource AppBackground}">

    <Grid RowDefinitions="*,Auto,Auto,Auto" Padding="16" RowSpacing="12">
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="4">
            <Grid x:Name="CameraHost" MinimumHeightRequest="280">
                <VerticalStackLayout IsVisible="{Binding HasCamera, Converter={StaticResource InvertedBoolConverter}}"
                                     VerticalOptions="Center" HorizontalOptions="Center" Spacing="12" Padding="24">
                    <Label Text="📷" FontSize="48" HorizontalOptions="Center" />
                    <Label Text="Kamera niedostępna"
                           TextColor="{StaticResource TextPrimary}"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center" />
                    <Label Text="{Binding StatusMessage}"
                           TextColor="{StaticResource MutedText}"
                           FontSize="13"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <Label Grid.Row="1" Text="{Binding StatusMessage}" HorizontalTextAlignment="Center"
               TextColor="{StaticResource AccentGreen}"
               IsVisible="{Binding HasCamera}" />

        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="14"
                IsVisible="{Binding ShowAuthResult}">
            <VerticalStackLayout Spacing="6">
                <Label Text="Nie udało się"
                       TextColor="{StaticResource DangerRed}"
                       FontAttributes="Bold"
                       FontSize="15"
                       HorizontalTextAlignment="Center" />
                <Label Text="{Binding AuthResultMessage}"
                       TextColor="{StaticResource DangerRed}"
                       FontSize="13"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Border>

        <Grid Grid.Row="3" ColumnDefinitions="*,*" ColumnSpacing="12">
            <Button Grid.Column="0" Text="Anuluj" Command="{Binding CancelCommand}" Style="{StaticResource OutlineButton}" />
            <Button Grid.Column="1" Text="Zrób zdjęcie" Command="{Binding CaptureCommand}"
                    Style="{StaticResource AccentButton}" IsEnabled="{Binding IsCameraReady}" />
        </Grid>

        <ActivityIndicator Grid.RowSpan="4" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                           Color="{StaticResource AccentGreen}" VerticalOptions="Center" />
    </Grid>
</ContentPage>
