<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MeBio"
             xmlns:conv="clr-namespace:MeBio.Converters"
             x:Class="MeBio.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
                <ResourceDictionary Source="Resources/Styles/AppStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:StringNotEmptyConverter x:Key="StringNotEmptyConverter" />
            <conv:GenderConverter x:Key="GenderConverter" />
            <conv:LoginMethodConverter x:Key="LoginMethodConverter" />
            <conv:LoginMethodColorConverter x:Key="LoginMethodColorConverter" />
            <conv:SuccessColorConverter x:Key="SuccessColorConverter" />
            <conv:BoolToResultTextConverter x:Key="BoolToResultTextConverter" />
            <conv:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
