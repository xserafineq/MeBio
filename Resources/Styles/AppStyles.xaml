<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style x:Key="AppTitle" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource AccentGreen}" />
        <Setter Property="FontSize" Value="36" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="HorizontalOptions" Value="Center" />
    </Style>

    <Style x:Key="AppSubtitle" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource MutedText}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="HorizontalOptions" Value="Center" />
    </Style>

    <Style x:Key="SectionTitle" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style x:Key="FieldLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource MutedText}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="StatLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource MutedText}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="StatValue" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource AccentGreen}" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style x:Key="StatusLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource AccentGreen}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <Style x:Key="CardBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource CardBackground}" />
        <Setter Property="Stroke" Value="{StaticResource BorderColor}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 12" />
    </Style>

    <Style x:Key="StatCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource CardBackground}" />
        <Setter Property="Stroke" Value="{StaticResource BorderColor}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 10" />
    </Style>

    <Style x:Key="DarkEntry" TargetType="Entry">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource Gray400}" />
        <Setter Property="BackgroundColor" Value="{StaticResource MidnightBlue}" />
    </Style>

    <Style x:Key="AccentButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource AccentGreen}" />
        <Setter Property="TextColor" Value="{StaticResource Black}" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16,12" />
    </Style>

    <Style x:Key="OutlineButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource AccentGreen}" />
        <Setter Property="BorderColor" Value="{StaticResource AccentGreen}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16,12" />
    </Style>

    <Style x:Key="LinkButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource MutedText}" />
    </Style>

    <Style x:Key="SmallOutlineButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource AccentGreen}" />
        <Setter Property="BorderColor" Value="{StaticResource BorderColor}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style x:Key="BiometricCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource MidnightBlue}" />
        <Setter Property="Stroke" Value="{StaticResource BorderColor}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 12" />
        <Setter Property="Padding" Value="16,20" />
    </Style>

    <Style x:Key="BiometricCardTitle" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <Style x:Key="BiometricCardHint" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource MutedText}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <Style x:Key="DividerLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource MutedText}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <Style x:Key="SmallDangerButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource DangerRed}" />
        <Setter Property="BorderColor" Value="{StaticResource BorderColor}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>

</ResourceDictionary>
