<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MeBio.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    FlyoutBehavior="Disabled"
    Shell.BackgroundColor="{StaticResource AppBackground}"
    Shell.ForegroundColor="{StaticResource TextPrimary}"
    Shell.TitleColor="{StaticResource AccentGreen}"
    Shell.TabBarBackgroundColor="{StaticResource CardBackground}"
    Shell.TabBarForegroundColor="{StaticResource AccentGreen}"
    Shell.TabBarUnselectedColor="{StaticResource MutedText}" />
